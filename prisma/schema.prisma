generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       Int      @id @default(autoincrement())
  username String
  email    String   @unique
  password String
  role     String   @default("user")
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  position  String
  salary    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
